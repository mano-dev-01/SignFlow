<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleExecutable</key>
	<string>SignFlow</string>
	<key>CFBundleIdentifier</key>
	<string>com.signflow.app</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>SignFlow</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	
	<!-- Privacy and Permissions (REQUIRED) -->
	<key>NSCameraUsageDescription</key>
	<string>SignFlow needs camera access to recognize American Sign Language (ASL) gestures and provide real-time captions.</string>
	
	<key>NSMicrophoneUsageDescription</key>
	<string>SignFlow optionally uses the microphone for voice-to-text input during sign language recognition sessions.</string>
	
	<key>NSLocalNetworkUsageDescription</key>
	<string>SignFlow may communicate with local services for model inference and caption processing.</string>
	
	<key>NSBonjourServiceTypes</key>
	<array>
		<string>_http._tcp</string>
	</array>
	
	<!-- Screen Recording Permission (REQUIRED for macOS 10.15+) -->
	<key>NSScreenCaptureUsageDescription</key>
	<string>SignFlow needs screen recording access to capture windows for real-time sign language recognition.</string>
	
	<!-- Allow Background Activity -->
	<key>UIBackgroundModes</key>
	<array>
		<string>processing</string>
	</array>
	
	<!-- macOS Specific -->
	<key>LSMinimumSystemVersion</key>
	<string>10.13</string>
	
	<key>NSHighResolutionCapable</key>
	<true/>
	
	<key>NSSupportsAutomaticGraphicsSwitching</key>
	<true/>
	
	<!-- Allow unsigned plugins/extensions -->
	<key>LSEnvironment</key>
	<dict>
		<key>DYLD_FRAMEWORK_PATH</key>
		<string>$(inherited)</string>
	</dict>
</dict>
</plist>
